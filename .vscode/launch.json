{
    "version": "0.2.0",
    "configurations": [
        
        {
            "name": "Python Debugger: Current File",
            "type": "debugpy",
            "request": "launch",
            "module": "streamlit",
            "args": [
                "run",
                "${file}",
                //"${workspaceFolder}/app.py",
                "--server.port",
                "8501"
            ],
            "jinja": true,
            "justMyCode": true
        }
    ]
}